{
  "name": "bookclaw",
  "version": "5.0.0",
  "description": "The Autonomous AI Writing Agent — 6 book production phases, author personas, pipeline mode, 21-step deep revision, KDP-ready export. Built for authors who scale.",
  "main": "gateway/src/index.ts",
  "type": "module",
  "workspaces": [
    "frontend/*"
  ],
  "scripts": {
    "start": "node --import tsx gateway/src/index.ts",
    "dev": "node --watch --import tsx gateway/src/index.ts",
    "build": "tsc",
    "build:frontend": "npm run -w frontend/studio build && npm run -w frontend/chat build",
    "setup": "bash scripts/setup-wizard.sh",
    "setup:legacy": "bash scripts/setup.sh",
    "recover": "bash scripts/recover.sh",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.yml down",
    "docker:logs": "docker-compose -f docker/docker-compose.yml logs -f",
    "security-audit": "node scripts/security-check.js",
    "export-book": "bash scripts/export-book.sh",
    "test": "npm run test:unit && npm run test:api && npm run test:smoke",
    "test:unit": "npm run build:frontend && node --import tsx --test tests/unit/*.test.ts",
    "test:api": "bash tests/api/api-test.sh",
    "test:smoke": "npm run build:frontend && bash tests/smoke-test.sh"
  },
  "keywords": [
    "ai",
    "agent",
    "author",
    "writing",
    "fiction",
    "nonfiction",
    "openclaw",
    "fork",
    "secure",
    "ollama",
    "claude",
    "gemini",
    "book",
    "manuscript",
    "editor",
    "writing-assistant"
  ],
  "author": "Christopher Kokoski (Writing Secrets)",
  "license": "MIT",
  "dependencies": {
    "@types/multer": "^2.0.0",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "docx": "^9.6.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "ipaddr.js": "^1.9.1",
    "jsonrepair": "^3.14.1",
    "multer": "^2.2.0",
    "node-diff3": "^3.2.1",
    "node-edge-tts": "^1.2.10",
    "socket.io": "^4.7.0",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.3",
    "marked": "^18.0.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "ws": "^8.21.0"
  }
}
