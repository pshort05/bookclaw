node_modules/
gateway/dist/
dist/
.env
config/.vault/
config/user.json

# Local API keys for testing (never commit secrets)
.keys

# Test-build trigger + logs (local to Mercury, see scripts/systemd/)
build_now
.build-logs/

# Transient commit message consumed + removed by ./push.sh (not tracked)
commit_message

# Deny-by-default: ignore everything under workspace/, then re-include ONLY the
# product-default files meant to ship with the repo. Prevents a stray `git add .`
# (push.sh) from ever committing the author's private manuscripts, memory,
# staged imports, generated covers, or voice fingerprints.
workspace/*
!workspace/soul/
!workspace/SKILLS.txt
!workspace/projects/
workspace/projects/*
!workspace/projects/.template/
*.log
.DS_Store
nul

# Claude Code config (local dev only)
.claude/

# Premium skill packs (purchased separately, not bundled)
skills/premium/*/
!skills/premium/README.md

# Source documents — scanned to generate content, never uploaded (README tracked)
sources/*
!sources/README.md

# Author OS tools (mounted at runtime)
author-os/

# Internal testing docs (not for repo)
scripts/FULL-TEST-CHECKLIST.md
ROADMAP.md

# Setup-specific deployment runbook (Neptune/Mercury hosts, paths, IPs — not for repo)
docs/DEPLOYMENT.local.md

# Frontend build artifacts (built by Docker/CI; not committed)
frontend/studio/dist/
frontend/chat/dist/
frontend/**/*.tsbuildinfo

# StoryScope research sources (local reference only; paper PDF + LaTeX)
research/
