# BookClaw MCP service environment. The installer copies this to
# ~/.config/bookclaw-mcp/bookclaw-mcp.env (chmod 600) and backfills the tokens.
# Secrets live ONLY in that file — never commit a filled-in copy.

# BookClaw gateway this MCP server proxies to
BOOKCLAW_BASE_URL=http://192.168.1.32:3847

# BookClaw's bearer token (the MCP server presents this to BookClaw)
BOOKCLAW_AUTH_TOKEN=

# Token that gates THIS MCP server (clients must present it as a Bearer token)
BOOKCLAW_MCP_TOKEN=

# Bind localhost-only; LLM clients on this machine connect via 127.0.0.1:3850
BOOKCLAW_MCP_BIND=127.0.0.1
BOOKCLAW_MCP_PORT=3850

# Tool surface: all | core | author | publishing | marketing
BOOKCLAW_MCP_PROFILE=all
