{
  "name": "bookclaw-mcp",
  "version": "0.1.0",
  "description": "MCP server for BookClaw",
  "type": "module",
  "engines": { "node": ">=22.0.0" },
  "scripts": {
    "start": "node --import tsx src/index.ts",
    "dev": "node --import tsx --watch src/index.ts",
    "build": "tsc",
    "test": "npm run test:unit && npm run test:smoke && npm run test:stdio",
    "test:unit": "node --import tsx --test tests/unit/*.test.ts",
    "test:smoke": "bash tests/smoke-test.sh",
    "test:stdio": "node tests/stdio-smoke.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
