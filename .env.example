# BookClaw Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or just run the setup wizard:
#   bash scripts/setup-wizard.sh

# REQUIRED: Vault encryption passphrase
# Pick any secure phrase — this encrypts your API keys on disk.
# Without this, API keys won't persist across restarts!
# If you don't set this, BookClaw will auto-generate one on first run.
BOOKCLAW_VAULT_KEY=

# OPTIONAL: Path to Author OS tools (if installed separately)
# AUTHOR_OS_PATH=/path/to/author-os

# OPTIONAL: Host directory bind-mounted as /app/workspace (books, library, soul,
# memory, projects, etc.). Defaults to /home/paul/bookclaw-workspace. Put it
# somewhere you can back up. The container runs as uid 1000, so the directory
# must be writable by that uid (deploy.sh creates it for you).
# BOOKCLAW_WORKSPACE_PATH=/home/paul/bookclaw-workspace

# OPTIONAL: Port for the standalone Chat app (Phase 6i onwards).
# Set this to enable the chat UI on a second port. The gateway auto-adds
# http://localhost:<port> + http://127.0.0.1:<port> to the CORS allowlist.
# For LAN access from other machines, also set BOOKCLAW_CORS_ORIGINS.
# BOOKCLAW_CHAT_PORT=3848

# OPTIONAL: Cross-origin browser origins allowed to call the gateway API.
# Comma-separated. Required for LAN clients of the chat app (e.g. http://192.168.1.32:3848).
# A literal "*" allows all origins (escape hatch, logged loudly — not recommended).
# BOOKCLAW_CORS_ORIGINS=http://192.168.1.32:3848

# OPTIONAL: LAN hostname/IP the studio and chat are reached at (e.g. 192.168.1.32).
# Used by the chat server to validate the Host header before injecting the bearer token
# and building the CSP connect-src. Normally not required — the hostname is already
# extracted from BOOKCLAW_CORS_ORIGINS automatically. Set this only if the chat host
# is not covered by BOOKCLAW_CORS_ORIGINS (belt-and-suspenders for non-CORS deployments).
# BOOKCLAW_PUBLIC_HOST=192.168.1.32
